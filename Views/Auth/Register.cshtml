@using WebApplication1.Dto
@model UserDto

<div>   @ViewBag.ErrorMessage</div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header text-center">
                    <h3>Login</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CreateUser" >
                        <div class="mb-3">
                            <label for="name" class="form-label">Name</label>
                            <input type="text"
                                   class="form-control"
                                   id="username"
                                   name="username"
                                   asp-for="UserName"
                                   placeholder="Enter your name"
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email</label>
                            <input type="email"
                                   class="form-control"
                                   id="email"
                                   name="email"
                                   asp-for="Email"
                                   placeholder="Enter your email"
                                   required>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password"
                                   class="form-control"
                                   id="password"
                                   name="password"
                                   asp-for="Password"
                                   placeholder="Enter your password"
                                   required>
                        </div>

                        <input type="submit" class="btn btn-primary w-100" value="sumbit">
                            
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


Existing User ? <a asp-action="Login">Login....</a>